<% content_for :title, "pingrb — support" %>
<% content_for :description, "How to get help with pingrb." %>

<main class="mx-auto w-full max-w-3xl grow px-4 py-12 text-sm sm:px-6 sm:py-20">
  <section>
    <p class="text-xs tracking-wide text-emerald-700 uppercase">support</p>
    <h1 class="mt-4 flex flex-wrap items-start gap-x-3 gap-y-1 text-2xl text-balance text-neutral-900 sm:text-3xl">
      <span class="-translate-y-px text-emerald-700">❯</span>
      <span>Support.</span>
    </h1>
  </section>

  <section class="mt-12 space-y-3 text-base text-neutral-700 text-pretty">
    <p>pingrb is built and operated by <%= link_to "Joe Masilotti", "https://masilotti.com", class: "text-emerald-700 hover:underline" %>. If something is broken, you have a question, or you want to request a feature, email <%= mail_to "joe@masilotti.com", class: "text-emerald-700 hover:underline" %>. I usually reply within a day.</p>
  </section>

</main>

<%= render "shared/footer" %>
