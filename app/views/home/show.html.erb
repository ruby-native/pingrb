<% content_for :title, "pingrb — a tiny push notification app to get alerts on anything" %>
<% content_for :description, "Stripe paid, deploy failed, agent finished. Anything that can POST lands as a push on your phone." %>

<header class="border-b border-neutral-950/10">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3 text-sm sm:px-6">
    <a href="/" aria-label="Homepage" class="text-emerald-700">
      <span class="text-neutral-500">$</span> pingrb
    </a>
    <%= link_to "sign in", new_session_path, class: "text-xs text-neutral-500 hover:text-neutral-900" %>
  </div>
</header>

<main class="mx-auto max-w-3xl px-4 py-12 text-sm sm:px-6 sm:py-20">
  <section>
    <p class="text-xs tracking-wide text-emerald-700 uppercase">alpha</p>
    <h1 class="mt-4 flex flex-wrap items-start gap-x-3 gap-y-1 text-2xl text-balance text-neutral-900 sm:text-3xl">
      <span class="-translate-y-px text-emerald-700">❯</span>
      <span>A tiny push notification app to get alerts on anything.</span>
    </h1>
    <p class="mt-5 max-w-[60ch] text-base text-neutral-600 text-pretty">Stripe paid, deploy failed, agent finished. Anything that can POST lands as a push on your phone.</p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <%= link_to "[ + get started ]", new_registration_path, class: "rounded-sm border border-emerald-700/30 bg-emerald-50 px-3 py-2 text-sm whitespace-nowrap text-emerald-700 hover:border-emerald-700 hover:bg-emerald-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      <%= link_to "sign in", new_session_path, class: "text-xs text-neutral-500 hover:text-neutral-900" %>
    </div>
  </section>

  <section class="mt-20 border-t border-neutral-950/10 pt-10">
    <p class="text-xs tracking-wide text-neutral-500 uppercase">examples</p>
    <ol class="mt-6 space-y-10 text-neutral-900">
      <li class="grid grid-cols-[auto_1fr] gap-x-4">
        <span class="text-emerald-700 tabular-nums">01</span>
        <div class="min-w-0">
          <p class="text-neutral-900">Tell me when I sell something.</p>
          <p class="mt-1 text-xs text-neutral-500">Paste this URL into Stripe for refunds, disputes, and cancellations too.</p>
          <pre class="mt-3 overflow-x-auto rounded-sm border border-neutral-950/10 bg-white px-3 py-2 text-xs text-neutral-900">https://pingrb.com/webhooks/stripe/<span class="text-emerald-700">&lt;your-token&gt;</span></pre>
        </div>
      </li>
      <li class="grid grid-cols-[auto_1fr] gap-x-4">
        <span class="text-emerald-700 tabular-nums">02</span>
        <div class="min-w-0">
          <p class="text-neutral-900">Tell me when my deploy fails.</p>
          <p class="mt-1 text-xs text-neutral-500">One curl, from anywhere that can POST.</p>
          <pre class="mt-3 overflow-x-auto rounded-sm border border-neutral-950/10 bg-white px-3 py-2 text-xs text-neutral-900">$ curl -X POST https://pingrb.com/webhooks/custom/<span class="text-emerald-700">&lt;your-token&gt;</span> \
    -d '{"title":"deploy failed"}'</pre>
        </div>
      </li>
      <li class="grid grid-cols-[auto_1fr] gap-x-4">
        <span class="text-emerald-700 tabular-nums">03</span>
        <div class="min-w-0">
          <p class="text-neutral-900">Give your agent a push button.</p>
          <p class="mt-1 text-xs text-neutral-500">A one-line CLI for Claude, Codex, anything.</p>
          <pre class="mt-3 overflow-x-auto rounded-sm border border-neutral-950/10 bg-white px-3 py-2 text-xs text-neutral-900">$ brew install ruby-native/tap/pingrb
&gt; pingrb me when you're done</pre>
        </div>
      </li>
    </ol>
  </section>

  <section class="mt-20 border-t border-neutral-950/10 pt-10">
    <p class="text-xs tracking-wide text-neutral-500 uppercase">sources</p>
    <ul role="list" class="mt-4 divide-y divide-neutral-950/10">
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">Stripe</span>
        <span class="text-xs text-neutral-500">payments, subscriptions, refunds, disputes</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">Cal.com</span>
        <span class="text-xs text-neutral-500">bookings, reschedules, cancellations</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">Hatchbox</span>
        <span class="text-xs text-neutral-500">failed deploys</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">StatusCake</span>
        <span class="text-xs text-neutral-500">site down, recovered</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">Agent</span>
        <span class="text-xs text-neutral-500">CLI for Claude, Codex, and any agent</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
      <li class="grid grid-cols-[8rem_1fr_auto] items-center gap-x-4 py-3">
        <span class="text-neutral-900">Custom</span>
        <span class="text-xs text-neutral-500">anything that can POST a JSON body</span>
        <span class="text-xs text-emerald-700">live</span>
      </li>
    </ul>
    <p class="mt-4 text-xs text-neutral-500">More as I need them. <%= link_to "Ping me", "mailto:joe@masilotti.com", class: "text-emerald-700 hover:underline" %> if you've got one in mind.</p>
  </section>

  <section class="mt-20 border-t border-neutral-950/10 pt-10 pb-4">
    <div class="flex flex-wrap items-center justify-between gap-3 text-xs text-neutral-500">
      <p>built by <%= link_to "joe masilotti", "https://masilotti.com", class: "text-emerald-700 hover:underline" %>.</p>
      <p>
        <%= link_to "sign up", new_registration_path, class: "hover:text-neutral-900" %>
        ·
        <%= link_to "sign in", new_session_path, class: "hover:text-neutral-900" %>
        ·
        <%= link_to "support", support_path, class: "hover:text-neutral-900" %>
        ·
        <%= link_to "privacy", privacy_path, class: "hover:text-neutral-900" %>
      </p>
    </div>
  </section>
</main>
