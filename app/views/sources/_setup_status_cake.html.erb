<ol class="mt-4 space-y-4 text-neutral-700">
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">01</span>
    <div>
      <p class="text-neutral-900">Open <%= link_to "StatusCake", "https://app.statuscake.com/", target: "_blank", rel: "noopener", class: "text-emerald-700 hover:underline" %>.</p>
      <p class="mt-1 text-xs text-neutral-500">Alerting &raquo; Contact Groups. Edit an existing group or create a new one.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">02</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Paste this into the <strong class="font-medium">WebHook URL</strong> field. Leave the method as POST.</p>
      <%= render "webhook_url_field", url: public_webhook_url(parser_type: source.parser_type, token: source.token) %>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">03</span>
    <div>
      <p class="text-neutral-900">Save the contact group.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">04</span>
    <div>
      <p class="text-neutral-900">If this is a new group, attach it to each Test you want pings for.</p>
      <p class="mt-1 text-xs text-neutral-500">StatusCake doesn't sign webhooks, so the token in the URL is the shared secret. Don't share the URL.</p>
    </div>
  </li>
</ol>
