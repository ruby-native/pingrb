<ol class="mt-4 space-y-4 text-neutral-700">
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">01</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Install the CLI.</p>
      <%= render "webhook_url_field", url: "brew install ruby-native/tap/pingrb" %>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">02</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Configure it with this token.</p>
      <%= render "webhook_url_field", url: "pingrb configure #{source.token}" %>
      <p class="mt-1 text-xs text-neutral-500">The token is the only auth, so don't share it. Rotate it below if it ever leaks.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">03</span>
    <div>
      <p class="text-neutral-900">Send a push from any shell or script.</p>
      <%= render "webhook_url_field", url: %(pingrb "deploy done" --body "main · a1b2c3d") %>
    </div>
  </li>
</ol>
