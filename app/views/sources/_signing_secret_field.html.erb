<div class="mt-4" data-controller="clipboard">
  <p class="text-xs tracking-wide text-neutral-500 uppercase">signing secret</p>
  <% if source.signing_secret.present? %>
    <div class="mt-2 flex items-center gap-2">
      <div class="min-w-0 flex-1 rounded-sm bg-neutral-200 pr-9">
        <pre data-clipboard-target="source" class="overflow-x-auto px-3 py-2 text-xs text-neutral-900"><%= source.signing_secret %></pre>
      </div>
      <button type="button" data-clipboard-target="button" data-action="clipboard#copy" class="min-w-18 shrink-0 rounded-sm border border-emerald-700/30 bg-emerald-50 px-3 py-2 text-sm whitespace-nowrap text-emerald-700 hover:border-emerald-700 hover:bg-emerald-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700">copy</button>
    </div>
    <p class="mt-2 text-xs text-emerald-700">Auto-generated. Webhooks are verified once <%= source.parser_type.titleize %> has this secret.</p>
  <% else %>
    <p class="mt-2 text-xs text-red-700">No signing secret set. Webhooks will be rejected until one is added.</p>
  <% end %>

  <div class="mt-3 flex flex-wrap items-center gap-3">
    <%= button_to (source.signing_secret.present? ? "regenerate" : "generate"), regenerate_signing_secret_source_path(source), method: :post, data: { turbo_confirm: source.signing_secret.present? ? "Regenerate the signing secret? The old secret stops working immediately and must be updated in #{source.parser_type.titleize}." : nil }, class: "rounded-sm border border-neutral-950/15 px-2.5 py-1.5 text-xs whitespace-nowrap text-neutral-700 hover:border-neutral-700 hover:bg-neutral-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700", form: { class: "contents" } %>
  </div>
</div>
