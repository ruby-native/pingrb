<ol class="mt-4 space-y-4 text-neutral-700">
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">01</span>
    <div>
      <p class="text-neutral-900">Open your <%= link_to "Honeybadger project", "https://app.honeybadger.io/", target: "_blank", rel: "noopener", class: "text-emerald-700 hover:underline" %>.</p>
      <p class="mt-1 text-xs text-neutral-500">Settings &raquo; Alerts &amp; Integrations &raquo; WebHook.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">02</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Paste this URL and pick which events to send.</p>
      <%= render "webhook_url_field", url: public_webhook_url(parser_type: source.parser_type, token: source.token) %>
      <p class="mt-2 text-xs text-neutral-500">Suggested: errors (occurred), uptime (down/up), missed check-ins.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">03</span>
    <div>
      <p class="text-neutral-900">Save the integration.</p>
      <p class="mt-1 text-xs text-neutral-500">Honeybadger doesn't sign webhooks, so there's no secret to configure here. Treat the token in the URL as the shared secret.</p>
    </div>
  </li>
</ol>
