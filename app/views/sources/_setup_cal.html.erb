<ol class="mt-4 space-y-4 text-neutral-700">
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">01</span>
    <div>
      <p class="text-neutral-900">Open <%= link_to "Cal.com webhooks", "https://app.cal.com/settings/developer/webhooks", target: "_blank", rel: "noopener", class: "text-emerald-700 hover:underline" %>.</p>
      <p class="mt-1 text-xs text-neutral-500">Settings &raquo; Developer &raquo; Webhooks &raquo; New Webhook.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">02</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Paste this Subscriber URL.</p>
      <%= render "webhook_url_field", url: public_webhook_url(parser_type: source.parser_type, token: source.token) %>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">03</span>
    <div>
      <p class="text-neutral-900">Subscribe to the events that matter, for example:</p>
      <ul role="list" class="mt-2 space-y-1 text-xs text-neutral-500">
        <li><code class="text-neutral-700">BOOKING_CREATED</code> — new booking</li>
        <li><code class="text-neutral-700">BOOKING_RESCHEDULED</code> — rescheduled</li>
        <li><code class="text-neutral-700">BOOKING_CANCELLED</code> — cancelled</li>
      </ul>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">04</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Copy this signing secret and paste it into the Cal.com Secret field.</p>
      <p class="mt-1 text-xs text-neutral-500">Cal.com signs each request with HMAC-SHA256 using this secret.</p>
      <%= render "signing_secret_field", source: source %>
    </div>
  </li>
</ol>
