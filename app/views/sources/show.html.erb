<%= turbo_stream_from @source %>

<%= native_navbar_tag @source.name do |navbar| %>
  <% navbar.button icon: "ellipsis", position: :trailing do |menu| %>
    <% unless @source.parser.requires_signing_secret? %>
      <% menu.item "Rotate URL", click: "[data-rotate-button]" %>
    <% end %>
    <% menu.item "Remove source", click: "[data-remove-button]" %>
  <% end %>
<% end %>

<main class="mx-auto max-w-3xl px-4 py-6 text-sm sm:px-6 sm:py-8">
  <%= render "shared/page_header", title: @source.name do %>
    <%= link_to "~/sources", sources_path, class: "hover:text-neutral-900" %>/<%= @source.parser_type %>
  <% end %>

  <% needs_setup = (@source.parser.requires_signing_secret? && @source.signing_secret.blank?) || @notifications.none? %>
  <details class="group -mx-4 bg-neutral-50 px-5 py-4 sm:mx-0 sm:rounded-sm"<%= " open" if needs_setup %>>
    <summary class="flex cursor-pointer items-center justify-between list-none [&::-webkit-details-marker]:hidden">
      <span class="text-xs tracking-wide text-neutral-500 uppercase">setup</span>
      <span class="text-xs text-neutral-400 group-open:hidden">show</span>
      <span class="hidden text-xs text-neutral-400 group-open:inline">hide</span>
    </summary>
    <div class="mt-4">
      <%= render "setup_#{@source.parser_type}", source: @source %>
    </div>
    <div class="mt-8 border-t border-neutral-950/10 pt-5">
      <p class="text-xs tracking-wide text-neutral-500 uppercase">test</p>
      <div class="mt-4">
        <%= render "test_#{@source.parser_type}", source: @source %>
      </div>
    </div>
  </details>

  <section class="mt-6 -mx-4 bg-neutral-50 px-5 pt-4 sm:mx-0 sm:rounded-sm">
    <p class="text-xs tracking-wide text-neutral-500 uppercase tabular-nums">recent · <%= @notifications.count.to_s.rjust(4, "0") %></p>
    <% if @notifications.any? %>
      <ul role="list" class="mt-4 -mx-5">
        <% @notifications.each do |n| %>
          <li class="grid grid-cols-[1fr_auto] gap-x-4 px-5 py-3 sm:gap-x-6">
            <div class="min-w-0">
              <p class="truncate text-neutral-900"><%= n.title %></p>
              <p class="mt-0.5 truncate text-xs text-neutral-500"><%= n.body %></p>
              <% if n.url.present? %>
                <%= link_to "open ↗", n.url, target: "_blank", rel: "noopener", class: "mt-1 inline-block text-xs text-emerald-700 hover:underline" %>
              <% end %>
            </div>
            <span class="shrink-0 text-xs text-neutral-500 tabular-nums"><%= time_ago_in_words(n.received_at) %> ago</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="py-8 text-center text-neutral-500">
        <span class="text-neutral-400">$</span> no notifications yet. trigger one from <%= @source.parser_type.titleize %> to test.
      </p>
    <% end %>
  </section>

  <section class="native-hidden mt-8 flex items-center justify-end gap-2">
    <% unless @source.parser.requires_signing_secret? %>
      <%= button_to "[ rotate URL ]", rotate_source_path(@source), method: :post, data: { turbo_confirm: "Rotate the webhook URL? The old URL stops working immediately.", rotate_button: "" }, class: "rounded-sm border border-neutral-950/15 px-2.5 py-1.5 text-sm whitespace-nowrap text-neutral-700 hover:border-neutral-700 hover:bg-neutral-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700", form: { class: "contents" } %>
    <% end %>
    <%= button_to "[ remove source ]", @source, method: :delete, data: { turbo_confirm: "Remove #{@source.name}? This cannot be undone.", remove_button: "" }, class: "rounded-sm border border-red-700/30 px-2.5 py-1.5 text-sm whitespace-nowrap text-red-700 hover:border-red-700 hover:bg-red-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700", form: { class: "contents" } %>
  </section>
</main>
