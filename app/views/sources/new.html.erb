<main class="mx-auto max-w-md px-4 py-8 text-sm sm:px-6 sm:py-10">
  <p class="text-xs tracking-wide text-neutral-500 uppercase">
    <%= link_to "~/sources", sources_path, class: "hover:text-neutral-900" %>
  </p>
  <h1 class="mt-2 flex items-center gap-2 text-lg text-neutral-900">
    <span class="-translate-y-px text-emerald-700">❯</span>
    <span>new source</span>
  </h1>

  <%= form_with model: @source, class: "mt-8 space-y-5" do |form| %>
    <% if @source.errors.any? %>
      <div class="border-l-2 border-red-700 bg-red-50 px-3 py-2 text-red-900">
        <span class="text-xs text-red-700">[err]</span>
        <ul role="list" class="mt-1 list-disc pl-5 text-xs">
          <% @source.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-xs tracking-wide text-neutral-500 uppercase" %>
      <%= form.text_field :name, required: true, autofocus: true, placeholder: "e.g. Stripe production", class: "mt-2 block w-full rounded-sm border border-neutral-950/15 bg-white px-3 py-2 text-sm text-neutral-900 placeholder:text-neutral-400 max-sm:text-base focus:border-emerald-700 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-700" %>
    </div>

    <div>
      <%= form.label :parser_type, "Type", class: "block text-xs tracking-wide text-neutral-500 uppercase" %>
      <span class="mt-2 inline-grid w-full grid-cols-[1fr_--spacing(8)]">
        <%= form.select :parser_type, Source::CREATABLE_PARSER_TYPES.map { |t| [ t, t ] }, { prompt: "pick a source" }, class: "col-span-full row-start-1 appearance-none rounded-sm border border-neutral-950/15 bg-white py-2 pr-8 pl-3 text-sm text-neutral-900 focus:border-emerald-700 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-700" %>
        <svg viewBox="0 0 8 5" width="8" height="5" fill="none" class="pointer-events-none col-start-2 row-start-1 place-self-center text-neutral-500">
          <path d="M.5.5 4 4 7.5.5" stroke="currentcolor" />
        </svg>
      </span>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= form.submit "[ + add source ]", class: "rounded-sm border border-emerald-700/30 bg-emerald-50 px-3 py-2 text-sm text-emerald-700 hover:border-emerald-700 hover:bg-emerald-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      <%= link_to "cancel", sources_path, class: "text-xs text-neutral-500 hover:text-neutral-900" %>
    </div>
  <% end %>
</main>
