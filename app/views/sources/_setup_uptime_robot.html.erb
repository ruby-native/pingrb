<ol class="mt-4 space-y-4 text-neutral-700">
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">01</span>
    <div>
      <p class="text-neutral-900">Open <%= link_to "UptimeRobot", "https://dashboard.uptimerobot.com/integrations", target: "_blank", rel: "noopener", class: "text-emerald-700 hover:underline" %>.</p>
      <p class="mt-1 text-xs text-neutral-500">My Settings &raquo; Add Alert Contact &raquo; Webhook.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">02</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Paste this URL to Notify.</p>
      <%= render "webhook_url_field", url: public_webhook_url(parser_type: source.parser_type, token: source.token) %>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">03</span>
    <div class="min-w-0">
      <p class="text-neutral-900">Enable <strong class="font-medium">Send as POST</strong> and paste this as the POST value.</p>
      <%= render "webhook_url_field", url: "monitor=*monitorFriendlyName*&url=*monitorURL*&type=*alertTypeFriendlyName*&details=*alertDetails*" %>
      <p class="mt-2 text-xs text-neutral-500">UptimeRobot expands the <code class="text-neutral-700">*placeholders*</code> when it fires an alert.</p>
    </div>
  </li>
  <li class="grid grid-cols-[auto_1fr] gap-x-4">
    <span class="text-emerald-700 tabular-nums">04</span>
    <div>
      <p class="text-neutral-900">Save the alert contact and attach it to the monitors you want pings for.</p>
      <p class="mt-1 text-xs text-neutral-500">UptimeRobot doesn't sign webhooks, so the token in the URL is the shared secret. Don't share the URL.</p>
    </div>
  </li>
</ol>
