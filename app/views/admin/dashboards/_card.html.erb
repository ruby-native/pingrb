<section class="border border-neutral-950/10 px-4 py-4 sm:px-5">
  <header class="flex items-baseline justify-between border-b border-neutral-950/10 pb-3">
    <h2 class="text-xs tracking-wide text-neutral-500 uppercase"><%= title %></h2>
    <span class="font-medium text-emerald-700 tabular-nums"><%= count.to_s.rjust(4, "0") %></span>
  </header>
  <dl class="mt-3 divide-y divide-neutral-950/10">
    <% rows.each do |label, value| %>
      <div class="flex items-baseline justify-between py-2">
        <dt class="text-neutral-500"><%= label %></dt>
        <dd class="tabular-nums <%= value.to_i.zero? ? 'text-neutral-400' : 'text-neutral-900' %>"><%= value.to_i.to_s.rjust(4, "0") %></dd>
      </div>
    <% end %>
  </dl>
</section>
