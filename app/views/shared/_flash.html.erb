<% if flash[:notice].present? || flash[:alert].present? %>
  <div class="mx-auto w-full max-w-3xl px-4 pt-6 text-sm sm:px-6">
    <% if flash[:notice].present? %>
      <div class="border-l-2 border-emerald-700 bg-emerald-50 px-3 py-2 text-emerald-900">
        <span class="text-xs text-emerald-700">[ok]</span> <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert].present? %>
      <div class="border-l-2 border-red-700 bg-red-50 px-3 py-2 text-red-900">
        <span class="text-xs text-red-700">[err]</span> <%= flash[:alert] %>
      </div>
    <% end %>
  </div>
<% end %>
